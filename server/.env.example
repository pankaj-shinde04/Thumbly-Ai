# Server Configuration
PORT=4000
NODE_ENV=development

# Database
DATABASE_URL=mongodb://localhost:27017/thumbly-ai
# For MongoDB Atlas: mongodb+srv://username:password@cluster.mongodb.net/thumbly-ai

# CORS
CORS_ORIGIN=http://localhost:5173

# JWT Configuration
JWT_ACCESS_SECRET=your-super-secret-jwt-access-key-change-this-in-production
JWT_REFRESH_SECRET=your-super-secret-jwt-refresh-key-change-this-in-production
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=30d

# Storage Configuration
STORAGE_DRIVER=local
# For local development
UPLOAD_DIR=uploads
# For production (S3)
# S3_BUCKET=your-bucket-name
# S3_REGION=us-east-1
# S3_ACCESS_KEY=your-access-key
# S3_SECRET_KEY=your-secret-key

# AI Provider Configuration
AI_PROVIDER=openai
AI_API_KEY=your-ai-api-key

# Google Cloud Configuration (for Imagen)
GOOGLE_CLOUD_PROJECT_ID=your-google-cloud-project-id
GOOGLE_CLOUD_LOCATION=us-central1
# Get credentials from: https://console.cloud.google.com/apis/credentials
# Copy the entire JSON content and paste it below (as a single line or use a file)
# GOOGLE_CLOUD_CREDENTIALS='{"type":"service_account",...}'

# Logging
LOG_LEVEL=info
LOG_FILE=logs/app.log

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
